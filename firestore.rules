rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function - Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Simplified validation - only check essential security constraints
    function isValidAppointment(appointment) {
      return appointment.name is string && appointment.name.size() > 0 && appointment.name.size() <= 200
        && appointment.phone is string && appointment.phone.size() >= 10 && appointment.phone.size() <= 30
        && appointment.email is string && appointment.email.size() > 0 && appointment.email.size() <= 200
        && appointment.appointmentDate is string && appointment.appointmentDate.size() >= 8 && appointment.appointmentDate.size() <= 20
        && appointment.appointmentTime is string && appointment.appointmentTime.size() >= 4 && appointment.appointmentTime.size() <= 10
        && appointment.status in ['bekliyor', 'hazirlaniyor', 'hazir', 'tamamlandi']
        && appointment.createdAt is timestamp
        && appointment.updatedAt is timestamp;
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      // Allow anyone to create new appointments with basic validation
      allow create: if isValidAppointment(request.resource.data)
        && request.resource.data.status == 'bekliyor';
      
      // Only authenticated users can read, update, delete
      allow read, delete: if isAuthenticated();
      
      // Update: only status and updatedAt can be changed by authenticated users
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.status in ['bekliyor', 'hazirlaniyor', 'hazir', 'tamamlandi']
        && request.resource.data.updatedAt == request.time;
    }
    
    // Settings collection
    match /settings/{settingsId} {
      // Anyone can read settings (needed for public booking form)
      allow read: if true;
      
      // Only authenticated users can update settings
      allow create, update, delete: if isAuthenticated();
    }
    
    // Users collection
    match /users/{userId} {
      // Only authenticated users can access users collection
      allow read, write: if isAuthenticated();
    }
  }
}
